generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum EstadoPartido {
  FUTURO
  PROGRAMADO
  EN_JUEGO
  SUSPENDIDO
  CANCELADO
  TERMINADO
}

enum TipoEquipo {
  CLUB
  SELECCION
}

enum RolUsuario {
  USER
  ADMIN
}

model Usuario {
  id                   String           @id @default(cuid())
  nombre               String
  apellido             String?
  username             String           @unique
  email                String?          @unique
  emailVerificado      Boolean          @default(false)
  hashClave            String?
  googleId             String?          @unique
  telefono             String?
  hinchaDeEquipoId     String?
  rol                  RolUsuario       @default(USER)
  activo               Boolean          @default(true)
  fechaCreacion        DateTime         @default(now())
  fechaActualizacion   DateTime         @updatedAt
  hinchaDe             Equipo?          @relation("UsuarioHinchaDe", fields: [hinchaDeEquipoId], references: [id])
  predicciones         Prediccion[]
  torneosDeAmigos      TorneoDeAmigos[] @relation("UsuariosTorneosDeAmigos")

  @@index([hinchaDeEquipoId])
  @@index([email])
}

model Competencia {
  id                   String           @id @default(cuid())
  nombre               String
  slug                 String           @unique
  fechaCreacion        DateTime         @default(now())
  fechaActualizacion   DateTime         @updatedAt
  partidos             Partido[]
  torneosDeAmigos      TorneoDeAmigos[]
}

model TorneoDeAmigos {
  id                   String           @id @default(cuid())
  nombre               String
  competenciaId        String
  activo               Boolean          @default(true)
  fechaCreacion        DateTime         @default(now())
  fechaActualizacion   DateTime         @updatedAt
  competencia          Competencia      @relation(fields: [competenciaId], references: [id])
  usuarios             Usuario[]        @relation("UsuariosTorneosDeAmigos")

  @@index([competenciaId])
}

model Equipo {
  id                   String    @id @default(cuid())
  nombre               String
  nombreCompleto       String?
  tipo                 TipoEquipo @default(CLUB)
  slug                 String    @unique
  abreviatura          String?
  fechaInsercion       DateTime  @default(now())
  fechaActualizacion   DateTime  @updatedAt
  partidosComoEquipo1  Partido[] @relation("PartidoEquipo1")
  partidosComoEquipo2  Partido[] @relation("PartidoEquipo2")
  hinchas              Usuario[] @relation("UsuarioHinchaDe")
}

model Partido {
  id                   String         @id @default(cuid())
  competenciaId        String
  equipo1Id            String
  equipo2Id            String
  equipo1EsLocal       Boolean        @default(false)
  fecha                DateTime
  estado               EstadoPartido  @default(FUTURO)
  golesEquipo1         Int?
  golesEquipo2         Int?
  fechaCreacion        DateTime       @default(now())
  fechaActualizacion   DateTime       @updatedAt
  competencia          Competencia    @relation(fields: [competenciaId], references: [id], onDelete: Cascade)
  equipo1              Equipo         @relation("PartidoEquipo1", fields: [equipo1Id], references: [id])
  equipo2              Equipo         @relation("PartidoEquipo2", fields: [equipo2Id], references: [id])
  predicciones         Prediccion[]

  @@index([competenciaId])
  @@index([equipo1Id])
  @@index([equipo2Id])
  @@index([estado])
  @@index([fecha])
}

model Prediccion {
  id                         String    @id @default(cuid())
  partidoId                  String
  usuarioId                  String
  golesEquipo1Predicho       Int
  golesEquipo2Predicho       Int
  puntosOtorgados            Int?
  fechaCreacion              DateTime  @default(now())
  fechaActualizacion         DateTime  @updatedAt
  partido                    Partido   @relation(fields: [partidoId], references: [id], onDelete: Cascade)
  usuario                    Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([partidoId, usuarioId])
  @@index([usuarioId])
}

