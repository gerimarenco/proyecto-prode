DATABASE_URL="postgresql://USER:PASSWORD@HOST.postgres.database.azure.com:5432/prode_dev?sslmode=require"
JWT_SECRET="change-this-to-a-long-random-secret"
GOOGLE_CLIENT_ID="your-google-oauth-client-id.apps.googleusercontent.com"
PORT=3000
NODE_ENV=development

# Comma-separated browser origins allowed to call the API directly (Capacitor, local dev servers).
# Not required when the web app uses same-origin /api via Azure Static Web Apps proxy.
# Example: http://localhost:8080,https://your-app.azurestaticapps.net,capacitor://localhost,https://localhost
CORS_ORIGINS="http://localhost:8080,http://127.0.0.1:8080"
