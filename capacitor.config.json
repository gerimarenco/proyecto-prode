{
  "appId": "com.prodefootball.app",
  "appName": "ProdeFootball",
  "webDir": ".",
  "server": {
    "androidScheme": "https"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1200,
      "launchAutoHide": true,
      "backgroundColor": "#0a0a0f",
      "showSpinner": false,
      "androidSplashResourceName": "splash",
      "androidScaleType": "CENTER_CROP"
    },
    "StatusBar": {
      "style": "Dark",
      "backgroundColor": "#0a0a0f",
      "overlaysWebView": true
    },
    "Haptics": {}
  }
}
